---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const items = await getCollection("awards");
const sorted = items.sort((a, b) => b.data.year - a.data.year);
---

<Base title="荣誉" description="朱奕樟获得的奖项与荣誉列表。">
  <!-- Hero -->
  <section style="padding-bottom: 4rem; max-width: 880px; margin-left: auto; margin-right: auto;">
    <h1
      style="font-family: var(--font-display); font-size: clamp(2.4rem, 6vw, 3.4rem); font-weight: 500; color: var(--color-ink); letter-spacing: -0.02em; line-height: 1.1; margin: 0 0 0.75rem;"
    >
      荣誉
    </h1>
    <p
      style="font-family: var(--font-serif); font-size: 17px; font-style: italic; color: var(--color-ink-muted); margin: 0; line-height: 1.5;"
    >
      学业与项目相关获奖记录
    </p>
  </section>

  <!-- Awards list -->
  <section style="border-top: 1px solid var(--color-rule);">
    {sorted.length === 0 ? (
      <div style="padding: 4rem 0;">
        <p
          style="font-family: var(--font-serif); font-size: 16px; line-height: 1.9; color: var(--color-ink-muted); font-style: italic; max-width: 560px; margin: 0;"
        >
          获奖记录正在整理中。如有合作或交流意向，欢迎邮件联系。
        </p>
        <div style="margin-top: 2rem;">
          <a
            href="mailto:zhuyizhang0@gmail.com"
            style="font-family: var(--font-display); font-size: 13px; font-weight: 500; color: var(--color-accent); letter-spacing: 0.02em; border-bottom: none; transition: opacity 200ms ease;"
            onmouseover="this.style.opacity='0.75'"
            onmouseout="this.style.opacity='1'"
          >
            → 发邮件联系
          </a>
        </div>
      </div>
    ) : (
      <div>
        {sorted.map((item) => (
          <div style="display: flex; align-items: baseline; gap: 0.75rem; padding: 0.9rem 0; border-bottom: 1px solid var(--color-rule); flex-wrap: wrap;">
            <span
              style="font-family: var(--font-display); font-size: 13px; color: var(--color-ink-muted); font-variant-numeric: tabular-nums; flex-shrink: 0; min-width: 3rem;"
            >
              {item.data.year}
            </span>
            <span style="color: var(--color-rule); flex-shrink: 0;">·</span>
            <span
              style="font-family: var(--font-serif); font-size: 15px; font-weight: 500; color: var(--color-ink); flex: 1; min-width: 0;"
            >
              {item.data.title}
            </span>
            <span style="color: var(--color-rule); flex-shrink: 0;">·</span>
            <span
              style="font-family: var(--font-display); font-size: 13px; color: var(--color-ink-muted); flex-shrink: 0;"
            >
              {item.data.issuer}
            </span>
            {item.data.note && (
              <div style="width: 100%; padding-left: calc(3rem + 0.75rem + 0.75rem + 0.75rem);">
                <span
                  style="font-family: var(--font-serif); font-size: 13px; font-style: italic; color: var(--color-ink-muted);"
                >
                  {item.data.note}
                </span>
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </section>
</Base>
