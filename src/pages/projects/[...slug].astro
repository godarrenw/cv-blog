---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const { title, year, tags, cover, repo, demo, summary } = project.data;
---

<Base title={title} description={summary}>
  <!-- Back link -->
  <div style="margin-bottom: 3rem;">
    <a
      href="/projects"
      style="font-family: var(--font-display); font-size: 13px; font-weight: 500; color: var(--color-ink-muted); letter-spacing: 0.02em; border-bottom: none; transition: color 200ms ease;"
      onmouseover="this.style.color='var(--color-accent)'"
      onmouseout="this.style.color='var(--color-ink-muted)'"
    >
      ← 项目
    </a>
  </div>

  <article style="max-width: 680px;">
    <!-- Header -->
    <header style="margin-bottom: 3rem;">
      <h1
        style="font-family: var(--font-display); font-size: clamp(1.8rem, 5vw, 2.6rem); font-weight: 500; color: var(--color-ink); letter-spacing: -0.02em; line-height: 1.15; margin: 0 0 1rem;"
      >
        {title}
      </h1>
      <p
        style="font-family: var(--font-display); font-size: 13px; color: var(--color-ink-muted); margin: 0; letter-spacing: 0.04em; font-variant-numeric: tabular-nums;"
      >
        {year}
        {tags.map((tag, i) => (
          <span>
            <span style="margin: 0 0.45rem; color: var(--color-rule);">·</span>
            {tag}
          </span>
        ))}
      </p>
    </header>

    <!-- Cover image -->
    {cover && (
      <div style="margin-bottom: 3rem;">
        <img
          src={cover}
          alt={title}
          style="width: 100%; max-height: 320px; object-fit: cover; display: block;"
        />
      </div>
    )}

    <!-- Repo / Demo links -->
    {(repo || demo) && (
      <div style="display: flex; gap: 1.5rem; margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid var(--color-rule);">
        {repo && (
          <a
            href={repo}
            target="_blank"
            rel="noopener"
            style="font-family: var(--font-display); font-size: 13px; font-weight: 500; color: var(--color-accent); letter-spacing: 0.02em; border-bottom: none; transition: opacity 200ms ease;"
            onmouseover="this.style.opacity='0.75'"
            onmouseout="this.style.opacity='1'"
          >
            → GitHub
          </a>
        )}
        {demo && (
          <a
            href={demo}
            target="_blank"
            rel="noopener"
            style="font-family: var(--font-display); font-size: 13px; font-weight: 500; color: var(--color-accent); letter-spacing: 0.02em; border-bottom: none; transition: opacity 200ms ease;"
            onmouseover="this.style.opacity='0.75'"
            onmouseout="this.style.opacity='1'"
          >
            → Demo
          </a>
        )}
      </div>
    )}

    <!-- Content -->
    <div
      style="font-family: var(--font-serif); font-size: 16px; line-height: 1.85; color: var(--color-ink);"
      class="prose-content"
    >
      <Content />
    </div>

    <!-- Footer -->
    <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--color-rule);">
      <a
        href="/projects"
        style="font-family: var(--font-display); font-size: 13px; font-weight: 500; color: var(--color-ink-muted); letter-spacing: 0.02em; border-bottom: none; transition: color 200ms ease;"
        onmouseover="this.style.color='var(--color-accent)'"
        onmouseout="this.style.color='var(--color-ink-muted)'"
      >
        ← 返回项目列表
      </a>
    </div>
  </article>
</Base>

<style>
  .prose-content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 2.5rem 0 0.75rem;
    letter-spacing: 0.01em;
  }
  .prose-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 2rem 0 0.5rem;
    letter-spacing: 0.01em;
  }
  .prose-content :global(p) {
    margin: 0 0 1.25rem;
  }
  .prose-content :global(ul),
  .prose-content :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }
  .prose-content :global(li) {
    margin-bottom: 0.4rem;
  }
  .prose-content :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 200ms ease;
  }
  .prose-content :global(a:hover) {
    border-bottom-color: var(--color-accent);
  }
  .prose-content :global(code) {
    font-family: ui-monospace, monospace;
    font-size: 0.875em;
    background: var(--color-bg-card);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }
  .prose-content :global(pre) {
    background: var(--color-bg-card);
    padding: 1.25rem;
    overflow-x: auto;
    margin: 0 0 1.5rem;
    font-size: 0.875rem;
    line-height: 1.65;
  }
</style>
