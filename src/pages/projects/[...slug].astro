---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const { title, year, tags, cover, repo, demo, summary } = project.data;
---

<Base title={title} description={summary}>
  <article class="max-w-2xl">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-ink">{title}</h1>
      <div class="mt-3 flex flex-wrap items-center gap-3">
        <span class="text-sm text-ink-muted font-mono">{year}</span>
        {tags.map((tag) => (
          <span class="px-2 py-0.5 rounded bg-sysu-green-50 text-sysu-green text-xs font-medium">
            {tag}
          </span>
        ))}
      </div>
    </header>

    {cover && (
      <img
        src={cover}
        alt={title}
        class="w-full rounded-lg mb-8 object-cover max-h-64"
      />
    )}

    {(repo || demo) && (
      <div class="flex gap-3 mb-8">
        {repo && (
          <a
            href={repo}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded border border-sysu-green text-sysu-green text-sm font-medium hover:bg-sysu-green-50 transition-colors"
          >
            代码仓库 ↗
          </a>
        )}
        {demo && (
          <a
            href={demo}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded bg-sysu-green text-white text-sm font-medium hover:opacity-90 transition-opacity"
          >
            在线演示 ↗
          </a>
        )}
      </div>
    )}

    <div class="space-y-4 text-ink leading-relaxed">
      <Content />
    </div>

    <div class="mt-12 pt-6 border-t border-rule">
      <a href="/projects" class="text-sysu-green hover:underline text-sm font-medium">
        ← 返回项目列表
      </a>
    </div>
  </article>
</Base>
