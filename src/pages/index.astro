---
import Base from "../layouts/Base.astro";
import ProjectCard from "../components/ProjectCard.astro";
import PubItem from "../components/PubItem.astro";
import PrintButton from "../components/PrintButton.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);

const allPubs = await getCollection("publications");
const recentPubs = allPubs.sort((a, b) => b.data.year - a.data.year).slice(0, 3);
---

<Base
  title="朱奕樟 — Zhu Yizhang"
  description="朱奕樟 (Zhu Yizhang)，中山大学先进制造学院硕博连读，导师冯建设。研究关注 PHM、时空建模与量化。"
>
  <!-- Hero -->
  <section style="padding-bottom: 3rem; max-width: 880px; margin-left: auto; margin-right: auto;">

    <!-- Name row -->
    <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem 1.5rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
      <div style="flex: 1; min-width: 0;">
        <h1
          style="font-family: var(--font-display); font-size: clamp(1.7rem, 6vw, 3rem); font-weight: 500; color: var(--color-ink); letter-spacing: -0.02em; line-height: 1.1; margin: 0 0 0.35rem;"
        >
          朱奕樟 <span style="font-size: 0.55em; font-weight: 400; color: var(--color-ink-muted); letter-spacing: 0.01em;">Zhu Yizhang</span>
        </h1>
        <p
          style="font-family: var(--font-serif); font-size: 15px; font-style: italic; color: var(--color-ink-muted); margin: 0; line-height: 1.4;"
        >
          中山大学 · 先进制造学院 · 硕博连读 (2024–) &nbsp;|&nbsp; 导师：冯建设
        </p>
      </div>
      <div class="no-print" style="padding-top: 0.25rem; flex-shrink: 0;">
        <PrintButton label="下载 CV" variant="solid" />
      </div>
    </div>

    <!-- Research tags -->
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin: 1rem 0 1.25rem;">
      {["PHM", "时空建模", "量化研究"].map((tag) => (
        <span style="font-family: var(--font-display); font-size: 12px; font-weight: 500; letter-spacing: 0.04em; color: var(--color-accent); background: var(--color-accent-soft); border-radius: 4px; padding: 3px 10px; white-space: nowrap;">
          {tag}
        </span>
      ))}
    </div>

    <!-- Contact action row -->
    <div class="no-print" style="display: flex; gap: 0.25rem 1.5rem; flex-wrap: wrap; align-items: center; padding: 0.75rem 1rem; background: var(--color-bg-card); border-radius: 8px; border: 1px solid var(--color-rule);">
      <a
        id="copy-email-btn"
        href="mailto:zhuyzh56@mail2.sysu.edu.cn"
        style="font-family: var(--font-display); font-size: 13px; font-weight: 500; color: var(--color-accent); border-bottom: none; display: inline-flex; align-items: center; gap: 0.3rem; min-height: 36px; padding: 0.25rem 0;"
        title="点击复制邮箱，长按打开邮件"
      >
        → Email
      </a>
      <a
        href="https://github.com/godarrenw"
        target="_blank"
        rel="noopener"
        style="font-family: var(--font-display); font-size: 13px; font-weight: 500; color: var(--color-accent); border-bottom: none; display: inline-flex; align-items: center; gap: 0.3rem; min-height: 36px; padding: 0.25rem 0;"
      >
        → GitHub
      </a>
      <a
        href="/cv.pdf"
        download
        style="font-family: var(--font-display); font-size: 13px; font-weight: 500; color: var(--color-accent); border-bottom: none; display: inline-flex; align-items: center; gap: 0.3rem; min-height: 36px; padding: 0.25rem 0;"
      >
        → 下载 CV (PDF)
      </a>
      <span id="copy-confirm" style="font-family: var(--font-display); font-size: 12px; color: var(--color-accent); opacity: 0; transition: opacity 300ms ease; margin-left: 0.5rem;">已复制！</span>
    </div>
  </section>

  <script>
    const btn = document.getElementById("copy-email-btn");
    const confirm = document.getElementById("copy-confirm");
    btn?.addEventListener("click", (e) => {
      if (!navigator.clipboard) return;
      e.preventDefault();
      navigator.clipboard.writeText("zhuyzh56@mail2.sysu.edu.cn").then(() => {
        if (confirm) {
          confirm.style.opacity = "1";
          setTimeout(() => { confirm.style.opacity = "0"; }, 2000);
        }
      });
    });
  </script>

  <!-- 精选项目 -->
  <section style="padding: 4rem 0;">
    <header style="margin-bottom: 2rem;">
      <p
        style="font-family: var(--font-display); font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0 0 0.5rem;"
      >
        § 01
      </p>
      <h2
        style="font-family: var(--font-display); font-size: 15px; font-weight: 600; color: var(--color-ink); margin: 0; letter-spacing: 0.02em; text-transform: uppercase;"
      >
        精选项目
      </h2>
    </header>

    {featuredProjects.length > 0 ? (
      <div style="border-top: 1px solid var(--color-rule);">
        {featuredProjects.map((project, i) => (
          <div style="border-bottom: 1px solid var(--color-rule);">
            <ProjectCard
              href={`/projects/${project.id}`}
              title={project.data.title}
              summary={project.data.summary}
              year={project.data.year}
              tags={project.data.tags}
              cover={project.data.cover}
              index={i}
            />
          </div>
        ))}
      </div>
    ) : (
      <p style="font-family: var(--font-serif); font-style: italic; color: var(--color-ink-muted); font-size: 15px;">
        项目正在整理中，敬请期待。
      </p>
    )}

    <div style="margin-top: 1.75rem;">
      <a
        href="/projects"
        style="font-family: var(--font-display); font-size: 13px; font-weight: 500; color: var(--color-accent); letter-spacing: 0.02em; border-bottom: none; transition: opacity 200ms ease;"
        onmouseover="this.style.opacity='0.75'"
        onmouseout="this.style.opacity='1'"
      >
        → 查看完整项目列表
      </a>
    </div>
  </section>

  <!-- 最新论文 -->
  <section style="padding: 4rem 0;">
    <header style="margin-bottom: 2rem;">
      <p
        style="font-family: var(--font-display); font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0 0 0.5rem;"
      >
        § 02
      </p>
      <h2
        style="font-family: var(--font-display); font-size: 15px; font-weight: 600; color: var(--color-ink); margin: 0; letter-spacing: 0.02em; text-transform: uppercase;"
      >
        最新论文
      </h2>
    </header>

    {recentPubs.length > 0 ? (
      <div>
        {recentPubs.map((pub) => (
          <PubItem
            title={pub.data.title}
            authors={pub.data.authors}
            venue={pub.data.venue}
            year={pub.data.year}
            pdf={pub.data.pdf}
            doi={pub.data.doi}
            status={pub.data.status}
          />
        ))}
      </div>
    ) : (
      <p style="font-family: var(--font-serif); font-style: italic; color: var(--color-ink-muted); font-size: 15px; padding: 1.25rem 0; border-top: 1px solid var(--color-rule); border-bottom: 1px solid var(--color-rule);">
        博士期间论文正在准备中。
      </p>
    )}

    <div style="margin-top: 1.75rem;">
      <a
        href="/publications"
        style="font-family: var(--font-display); font-size: 13px; font-weight: 500; color: var(--color-accent); letter-spacing: 0.02em; border-bottom: none; transition: opacity 200ms ease;"
        onmouseover="this.style.opacity='0.75'"
        onmouseout="this.style.opacity='1'"
      >
        → 查看全部论文
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding: 4rem 0 2rem; border-top: 1px solid var(--color-rule); display: flex; gap: 0.5rem 2.5rem; flex-wrap: wrap;">
    <a
      href="/about"
      style="font-family: var(--font-display); font-size: 14px; font-weight: 500; color: var(--color-accent); letter-spacing: 0.02em; border-bottom: none; transition: opacity 200ms ease; display: inline-flex; align-items: center; min-height: 44px; padding: 0 0.25rem;"
      onmouseover="this.style.opacity='0.75'"
      onmouseout="this.style.opacity='1'"
    >
      → 关于我
    </a>
    <a
      href="mailto:zhuyzh56@mail2.sysu.edu.cn"
      style="font-family: var(--font-display); font-size: 14px; font-weight: 500; color: var(--color-accent); letter-spacing: 0.02em; border-bottom: none; transition: opacity 200ms ease; display: inline-flex; align-items: center; min-height: 44px; padding: 0 0.25rem;"
      onmouseover="this.style.opacity='0.75'"
      onmouseout="this.style.opacity='1'"
    >
      → 联系我
    </a>
  </section>
</Base>
