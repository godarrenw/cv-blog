---
import Base from "../layouts/Base.astro";
---

<Base title="关于我" description="朱奕樟的个人简介、教育经历与研究兴趣。">
  <section class="mb-10">
    <div class="flex items-start gap-6">
      <div
        class="w-24 h-24 rounded-full bg-sysu-green-50 flex items-center justify-center text-3xl font-bold text-sysu-green shrink-0"
      >
        朱
      </div>
      <div>
        <h1 class="text-3xl font-bold text-ink">朱奕樟</h1>
        <p class="mt-1 text-ink-muted">中山大学 · 博士研究生</p>
        <ul class="mt-3 space-y-1 text-sm text-ink">
          <li>
            <span class="text-ink-muted mr-2">邮箱</span>
            <a href="mailto:zhuyizhang0@gmail.com" class="text-sysu-green hover:underline">
              zhuyizhang0@gmail.com
            </a>
          </li>
          <li>
            <span class="text-ink-muted mr-2">GitHub</span>
            <a
              href="https://github.com/zhuyizhang"
              target="_blank"
              rel="noopener"
              class="text-sysu-green hover:underline"
            >
              github.com/zhuyizhang
            </a>
          </li>
          <li>
            <span class="text-ink-muted mr-2">ORCID</span>
            <a
              href="https://orcid.org/0000-0000-0000-0000"
              target="_blank"
              rel="noopener"
              class="text-sysu-green hover:underline"
            >
              0000-0000-0000-0000
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="mb-10">
    <h2 class="text-xl font-semibold text-ink border-b border-sysu-green pb-1 mb-6">
      教育经历
    </h2>
    <div class="relative pl-6 border-l-2 border-rule space-y-8">
      <div class="relative">
        <div
          class="absolute -left-[1.375rem] top-1 w-3 h-3 rounded-full bg-sysu-green border-2 border-white"
        ></div>
        <p class="text-sm text-ink-muted">2024 — 至今</p>
        <p class="font-semibold text-ink mt-0.5">中山大学</p>
        <p class="text-ink-muted text-sm">博士研究生 · PHM / 量化交易方向</p>
      </div>
      <div class="relative">
        <div
          class="absolute -left-[1.375rem] top-1 w-3 h-3 rounded-full bg-rule border-2 border-white"
        ></div>
        <p class="text-sm text-ink-muted">2020 — 2024</p>
        <p class="font-semibold text-ink mt-0.5">XX大学</p>
        <p class="text-ink-muted text-sm">本科 · XX专业（待补充）</p>
      </div>
    </div>
  </section>

  <section class="mb-10">
    <h2 class="text-xl font-semibold text-ink border-b border-sysu-green pb-1 mb-6">
      研究兴趣
    </h2>
    <div class="flex flex-wrap gap-2">
      {[
        "预测性维护（PHM）",
        "时序建模",
        "深度学习",
        "量化交易",
        "信号处理",
        "故障诊断",
        "数据驱动方法",
      ].map((tag) => (
        <span class="px-3 py-1 rounded-full bg-sysu-green-50 text-sysu-green text-sm font-medium">
          {tag}
        </span>
      ))}
    </div>
  </section>

  <section class="mb-10">
    <h2 class="text-xl font-semibold text-ink border-b border-sysu-green pb-1 mb-6">联系</h2>
    <ul class="space-y-2 text-ink">
      <li>
        <span class="text-ink-muted mr-2">邮箱</span>
        <a href="mailto:zhuyizhang0@gmail.com" class="text-sysu-green hover:underline">
          zhuyizhang0@gmail.com
        </a>
      </li>
      <li>
        <span class="text-ink-muted mr-2">GitHub</span>
        <a
          href="https://github.com/zhuyizhang"
          target="_blank"
          rel="noopener"
          class="text-sysu-green hover:underline"
        >
          github.com/zhuyizhang
        </a>
      </li>
      <li>
        <span class="text-ink-muted mr-2">ORCID</span>
        <a
          href="https://orcid.org/0000-0000-0000-0000"
          target="_blank"
          rel="noopener"
          class="text-sysu-green hover:underline"
        >
          0000-0000-0000-0000
        </a>
      </li>
    </ul>
  </section>
</Base>
