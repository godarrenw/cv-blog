---
import Base from "../layouts/Base.astro";
---

<Base title="关于我" description="朱奕樟的个人简介、教育经历与研究兴趣。">
  <!-- Hero -->
  <section style="padding-bottom: 4rem; max-width: 880px; margin-left: auto; margin-right: auto;">
    <h1
      style="font-family: var(--font-display); font-size: clamp(2.4rem, 6vw, 3.4rem); font-weight: 500; color: var(--color-ink); letter-spacing: -0.02em; line-height: 1.1; margin: 0 0 0.75rem;"
    >
      关于我
    </h1>
    <p
      style="font-family: var(--font-serif); font-size: 17px; font-style: italic; color: var(--color-ink-muted); margin: 0; line-height: 1.5;"
    >
      博士研究生 · 量化交易 / 时空建模 / PHM
    </p>

    <div style="display: flex; align-items: flex-start; gap: 1.25rem; margin-top: 2.25rem;">
      <div
        style="width: 64px; height: 64px; border-radius: 50%; background: var(--color-accent-soft); color: var(--color-accent); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 22px; font-weight: 600; flex-shrink: 0; margin-top: 0.15rem;"
      >
        朱
      </div>
      <p
        style="font-family: var(--font-serif); font-size: 17px; line-height: 1.8; color: var(--color-ink); margin: 0;"
      >
        我是朱奕樟，中山大学在读博士研究生。研究方向涵盖预测性维护（PHM）、时空数据建模与量化交易策略，致力于将深度学习与信号处理方法结合，解决工业传感器数据中的故障预测问题，同时探索数据驱动方法在金融市场中的应用。
      </p>
    </div>
  </section>

  <!-- § 01 教育 -->
  <section style="padding: 4rem 0; border-top: 1px solid var(--color-rule);">
    <header style="margin-bottom: 2rem;">
      <p
        style="font-family: var(--font-display); font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0 0 0.5rem;"
      >
        § 01
      </p>
      <h2
        style="font-family: var(--font-display); font-size: 15px; font-weight: 600; color: var(--color-ink); margin: 0; letter-spacing: 0.02em; text-transform: uppercase;"
      >
        教育
      </h2>
    </header>

    <div>
      <div style="display: flex; align-items: baseline; gap: 0.75rem; padding: 0.85rem 0; border-top: 1px solid var(--color-rule);">
        <span
          style="font-family: var(--font-display); font-size: 13px; color: var(--color-ink-muted); font-variant-numeric: tabular-nums; flex-shrink: 0; min-width: 7rem;"
        >
          2024 — 至今
        </span>
        <span
          style="font-family: var(--font-display); font-size: 14px; font-weight: 500; color: var(--color-ink);"
        >
          中山大学
        </span>
        <span style="color: var(--color-rule); font-size: 13px;">—</span>
        <span
          style="font-family: var(--font-serif); font-size: 14px; font-style: italic; color: var(--color-ink-muted);"
        >
          博士研究生 · PHM / 量化交易方向
        </span>
      </div>
      <div style="display: flex; align-items: baseline; gap: 0.75rem; padding: 0.85rem 0; border-top: 1px solid var(--color-rule); border-bottom: 1px solid var(--color-rule);">
        <span
          style="font-family: var(--font-display); font-size: 13px; color: var(--color-ink-muted); font-variant-numeric: tabular-nums; flex-shrink: 0; min-width: 7rem;"
        >
          2020 — 2024
        </span>
        <span
          style="font-family: var(--font-display); font-size: 14px; font-weight: 500; color: var(--color-ink);"
        >
          XX 大学
        </span>
        <span style="color: var(--color-rule); font-size: 13px;">—</span>
        <span
          style="font-family: var(--font-serif); font-size: 14px; font-style: italic; color: var(--color-ink-muted);"
        >
          本科 · XX 专业（待补充）
        </span>
      </div>
    </div>
  </section>

  <!-- § 02 研究兴趣 -->
  <section style="padding: 4rem 0; border-top: 1px solid var(--color-rule);">
    <header style="margin-bottom: 2rem;">
      <p
        style="font-family: var(--font-display); font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0 0 0.5rem;"
      >
        § 02
      </p>
      <h2
        style="font-family: var(--font-display); font-size: 15px; font-weight: 600; color: var(--color-ink); margin: 0; letter-spacing: 0.02em; text-transform: uppercase;"
      >
        研究兴趣
      </h2>
    </header>

    <p style="font-family: var(--font-serif); font-size: 16px; line-height: 2; color: var(--color-ink); margin: 0;">
      <span style="color: var(--color-accent); font-weight: 500;">时空状态空间模型</span>
      <span style="color: var(--color-ink-muted); margin: 0 0.6rem;">·</span>
      <span style="color: var(--color-accent); font-weight: 500;">风电预测</span>
      <span style="color: var(--color-ink-muted); margin: 0 0.6rem;">·</span>
      <span style="color: var(--color-accent); font-weight: 500;">故障预测与健康管理</span>
      <span style="color: var(--color-ink-muted); margin: 0 0.6rem;">·</span>
      <span style="color: var(--color-accent); font-weight: 500;">量化研究</span>
      <span style="color: var(--color-ink-muted); margin: 0 0.6rem;">·</span>
      <span style="color: var(--color-ink-muted);">深度学习 · 信号处理 · 时序建模</span>
    </p>
  </section>

  <!-- § 03 联系 -->
  <section style="padding: 4rem 0; border-top: 1px solid var(--color-rule);">
    <header style="margin-bottom: 2rem;">
      <p
        style="font-family: var(--font-display); font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0 0 0.5rem;"
      >
        § 03
      </p>
      <h2
        style="font-family: var(--font-display); font-size: 15px; font-weight: 600; color: var(--color-ink); margin: 0; letter-spacing: 0.02em; text-transform: uppercase;"
      >
        联系
      </h2>
    </header>

    <div style="display: flex; flex-direction: column; gap: 0; border-top: 1px solid var(--color-rule);">
      <div style="display: flex; align-items: baseline; gap: 2rem; padding: 0.85rem 0; border-bottom: 1px solid var(--color-rule);">
        <span
          style="font-family: var(--font-display); font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-ink-muted); min-width: 4.5rem; flex-shrink: 0;"
        >
          Email
        </span>
        <a
          href="mailto:zhuyizhang0@gmail.com"
          style="font-family: var(--font-serif); font-size: 15px; color: var(--color-accent); border-bottom: none; transition: opacity 200ms ease;"
          onmouseover="this.style.opacity='0.75'"
          onmouseout="this.style.opacity='1'"
        >
          zhuyizhang0@gmail.com
        </a>
      </div>
      <div style="display: flex; align-items: baseline; gap: 2rem; padding: 0.85rem 0; border-bottom: 1px solid var(--color-rule);">
        <span
          style="font-family: var(--font-display); font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-ink-muted); min-width: 4.5rem; flex-shrink: 0;"
        >
          GitHub
        </span>
        <a
          href="https://github.com/zhuyizhang"
          target="_blank"
          rel="noopener"
          style="font-family: var(--font-serif); font-size: 15px; color: var(--color-accent); border-bottom: none; transition: opacity 200ms ease;"
          onmouseover="this.style.opacity='0.75'"
          onmouseout="this.style.opacity='1'"
        >
          github.com/zhuyizhang
        </a>
      </div>
      <div style="display: flex; align-items: baseline; gap: 2rem; padding: 0.85rem 0; border-bottom: 1px solid var(--color-rule);">
        <span
          style="font-family: var(--font-display); font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-ink-muted); min-width: 4.5rem; flex-shrink: 0;"
        >
          ORCID
        </span>
        <a
          href="https://orcid.org/0000-0000-0000-0000"
          target="_blank"
          rel="noopener"
          style="font-family: var(--font-serif); font-size: 15px; color: var(--color-accent); border-bottom: none; transition: opacity 200ms ease;"
          onmouseover="this.style.opacity='0.75'"
          onmouseout="this.style.opacity='1'"
        >
          0000-0000-0000-0000
        </a>
      </div>
    </div>
  </section>
</Base>
