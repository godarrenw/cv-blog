---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  href: string;
  title: string;
  summary: string;
  year: number;
  tags: string[];
  cover?: ImageMetadata;
  index?: number;
}

const { href, title, summary, year, tags, cover, index } = Astro.props;
---

<a
  href={href}
  class="project-card"
  style="display: block; padding: 1.25rem 0; text-decoration: none; border-bottom: none; transition: transform 200ms ease;"
  onmouseover="this.style.transform='translateY(-2px)'; this.querySelector('.card-title').style.color='var(--color-accent)';"
  onmouseout="this.style.transform='translateY(0)'; this.querySelector('.card-title').style.color='var(--color-ink)';"
>
  <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;">
    <div style="display: flex; align-items: baseline; gap: 0.75rem; flex: 1; min-width: 0;">
      {index !== undefined && (
        <span
          style="font-family: var(--font-display); font-size: 12px; font-weight: 500; color: var(--color-accent); flex-shrink: 0; min-width: 1.5rem;"
        >
          {String(index + 1).padStart(2, "0")}
        </span>
      )}
      <h3
        class="card-title"
        style="font-family: var(--font-display); font-size: 15px; font-weight: 500; color: var(--color-ink); line-height: 1.4; transition: color 200ms ease; margin: 0;"
      >
        {title}
      </h3>
    </div>
    <span
      style="font-family: var(--font-display); font-size: 12px; color: var(--color-ink-muted); flex-shrink: 0; font-variant-numeric: tabular-nums;"
    >
      {year}
    </span>
  </div>

  <p
    style="font-family: var(--font-serif); font-size: 14px; color: var(--color-ink-muted); line-height: 1.65; margin: 0.4rem 0 0 {index !== undefined ? '2.25rem' : '0'};"
  >
    {summary}
  </p>

  {tags.length > 0 && (
    <div
      style={`margin-top: 0.5rem; margin-left: ${index !== undefined ? "2.25rem" : "0"}; display: flex; flex-wrap: wrap; gap: 0.25rem 0.5rem; align-items: center;`}
    >
      {tags.map((tag, i) => (
        <span style="font-family: var(--font-display); font-size: 12px; color: var(--color-ink-muted);">
          {i > 0 && <span style="color: var(--color-accent); margin-right: 0.4rem;">·</span>}
          {tag}
        </span>
      ))}
    </div>
  )}

  {cover && (
    <div style="margin-top: 0.75rem;">
      <Image
        src={cover}
        alt={`${title} 封面`}
        widths={[400, 800, 1200]}
        sizes="(max-width: 768px) 100vw, 680px"
        loading="lazy"
        decoding="async"
        style="width: 100%; max-height: 200px; object-fit: cover; display: block; border-radius: 4px;"
      />
    </div>
  )}
</a>
