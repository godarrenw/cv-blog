---
interface Props {
  href: string;
  title: string;
  summary: string;
  year: number;
  tags: string[];
  cover?: string;
}

const { href, title, summary, year, tags, cover } = Astro.props;
---

<a
  href={href}
  class="block border border-rule rounded-lg p-5 hover:border-sysu-green hover:shadow-sm transition-all no-underline group"
>
  {cover && (
    <img
      src={cover}
      alt={title}
      class="w-full h-36 object-cover rounded mb-4"
    />
  )}
  <div class="flex items-start justify-between gap-4">
    <h3 class="font-semibold text-ink group-hover:text-sysu-green transition-colors leading-snug">
      {title}
    </h3>
    <span class="text-xs text-ink-muted shrink-0 mt-0.5">{year}</span>
  </div>
  <p class="mt-2 text-sm text-ink-muted leading-relaxed">{summary}</p>
  {tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="bg-sysu-green-50 text-sysu-green text-xs px-2 py-0.5 rounded">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
