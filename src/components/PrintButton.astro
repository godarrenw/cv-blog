---
interface Props {
  label?: string;
  variant?: "solid" | "outline";
}

const { label = "下载 CV PDF", variant = "solid" } = Astro.props;

const solidStyle =
  "background: var(--color-accent); color: #fff; border: 1px solid var(--color-accent);";
const outlineStyle =
  "background: transparent; color: var(--color-accent); border: 1px solid var(--color-accent);";
const hoverSolid =
  "this.style.background='var(--color-accent-dark)'; this.style.borderColor='var(--color-accent-dark)';";
const hoverOutline =
  "this.style.background='var(--color-accent-soft)';";
const unhoverSolid =
  "this.style.background='var(--color-accent)'; this.style.borderColor='var(--color-accent)';";
const unhoverOutline =
  "this.style.background='transparent';";
---

<button
  id="print-btn"
  style={`font-family: var(--font-display); font-size: 13px; font-weight: 500; letter-spacing: 0.02em; border-radius: 6px; padding: 7px 20px; cursor: pointer; transition: background 200ms ease, border-color 200ms ease; ${variant === "solid" ? solidStyle : outlineStyle}`}
  onmouseover={variant === "solid" ? hoverSolid : hoverOutline}
  onmouseout={variant === "solid" ? unhoverSolid : unhoverOutline}
>
  {label}
</button>

<script>
  document.getElementById("print-btn")?.addEventListener("click", () => {
    window.print();
  });
</script>
