---
const pathname = Astro.url.pathname;

const links = [
  { href: "/about", label: "About" },
  { href: "/publications", label: "Publications" },
  { href: "/projects", label: "Projects" },
  { href: "/awards", label: "Awards" },
  { href: "/now", label: "Now" },
];

function isActive(href: string) {
  return pathname === href || pathname.startsWith(href + "/");
}
---

<header
  class="no-print sticky top-0 z-50"
  style="background: var(--color-bg); border-bottom: 1px solid var(--color-rule);"
>
  <nav
    class="mx-auto px-4 flex items-center justify-between h-14"
    style="max-width: 880px;"
  >
    <a
      href="/"
      class="font-display text-sm font-500 tracking-wide"
      style="font-family: var(--font-display); font-weight: 500; color: var(--color-ink); border-bottom: none; letter-spacing: 0.01em;"
    >
      朱奕樟
    </a>

    <!-- 桌面端 -->
    <div class="hidden md:flex items-center gap-7">
      {links.map(({ href, label }) => (
        <a
          href={href}
          style={`font-family: var(--font-display); font-size: 13px; letter-spacing: 0.02em; border-bottom: none; transition: color 200ms ease; color: ${isActive(href) ? "var(--color-ink)" : "var(--color-ink-muted)"};`}
        >
          {isActive(href) ? (
            <span style="position: relative; display: inline-block;">
              {label}
              <span
                style="position: absolute; bottom: -2px; left: 0; width: 16px; height: 2px; background: var(--color-accent); border-radius: 1px;"
              ></span>
            </span>
          ) : label}
        </a>
      ))}
      <button
        id="cv-btn"
        style="font-family: var(--font-display); font-size: 13px; border: 1px solid var(--color-accent); color: var(--color-accent); border-radius: 6px; padding: 4px 14px; background: transparent; cursor: pointer; transition: background 200ms ease, color 200ms ease; letter-spacing: 0.01em;"
        onmouseover="this.style.background='var(--color-accent-soft)'"
        onmouseout="this.style.background='transparent'"
      >
        CV
      </button>
    </div>

    <!-- 移动端汉堡 -->
    <button
      id="menu-btn"
      class="md:hidden flex flex-col gap-1.5"
      aria-label="菜单"
      style="background: none; border: none; cursor: pointer; padding: 0.625rem; margin-right: -0.625rem; min-width: 44px; min-height: 44px; align-items: center; justify-content: center;"
    >
      <span style="display: block; width: 20px; height: 1.5px; background: var(--color-ink);"></span>
      <span style="display: block; width: 20px; height: 1.5px; background: var(--color-ink);"></span>
      <span style="display: block; width: 20px; height: 1.5px; background: var(--color-ink);"></span>
    </button>
  </nav>

  <!-- 移动端菜单 -->
  <div
    id="mobile-menu"
    class="hidden md:hidden"
    style="border-top: 1px solid var(--color-rule); background: var(--color-bg);"
  >
    <div class="mx-auto px-6 py-4 flex flex-col gap-4" style="max-width: 880px;">
      {links.map(({ href, label }) => (
        <a
          href={href}
          style={`font-family: var(--font-display); font-size: 13px; letter-spacing: 0.02em; border-bottom: none; color: ${isActive(href) ? "var(--color-accent)" : "var(--color-ink-muted)"};`}
        >
          {label}
        </a>
      ))}
      <button
        id="cv-btn-mobile"
        style="font-family: var(--font-display); font-size: 13px; border: 1px solid var(--color-accent); color: var(--color-accent); border-radius: 6px; padding: 6px 14px; background: transparent; cursor: pointer; width: fit-content;"
      >
        CV
      </button>
    </div>
  </div>
</header>

<script>
  document.getElementById("menu-btn")?.addEventListener("click", () => {
    const menu = document.getElementById("mobile-menu");
    menu?.classList.toggle("hidden");
  });

  document.getElementById("cv-btn")?.addEventListener("click", () => {
    window.print();
  });

  document.getElementById("cv-btn-mobile")?.addEventListener("click", () => {
    window.print();
  });
</script>
