---
interface Props {
  title: string;
  authors: string;
  venue: string;
  year: number;
  pdf?: string;
  doi?: string;
  status: string;
}

const { title, authors, venue, year, pdf, doi, status } = Astro.props;

const statusColor: Record<string, string> = {
  "in-prep": "color: #b45309;",
  published: "color: var(--color-accent);",
  accepted: "color: var(--color-accent);",
  submitted: "color: var(--color-ink-muted);",
};

const statusLabel: Record<string, string> = {
  "in-prep": "草稿",
  published: "已发表",
  accepted: "已录用",
  submitted: "审稿中",
};
---

<div style="padding: 1.25rem 0; border-bottom: 1px solid var(--color-rule);">
  <p
    style="font-family: var(--font-serif); font-weight: 600; font-size: 15px; color: var(--color-ink); line-height: 1.45; margin: 0;"
  >
    {title}
  </p>
  <p
    style="font-family: var(--font-display); font-size: 13px; color: var(--color-ink-muted); margin: 0.35rem 0 0; letter-spacing: 0.01em;"
  >
    {authors}
    <span style="margin: 0 0.3rem; color: var(--color-rule);">·</span>
    <em style="font-style: normal;">{venue}</em>
    <span style="margin: 0 0.3rem; color: var(--color-rule);">·</span>
    {year}
    <span
      style={`margin-left: 0.6rem; font-family: var(--font-display); font-size: 12px; ${statusColor[status] ?? "color: var(--color-ink-muted);"}`}
    >
      [{statusLabel[status] ?? status}]
    </span>
  </p>
  {(pdf || doi) && (
    <div style="margin-top: 0.5rem; display: flex; gap: 1rem;">
      {pdf && (
        <a
          href={pdf}
          target="_blank"
          rel="noopener"
          style="font-family: var(--font-display); font-size: 12px; color: var(--color-accent); letter-spacing: 0.02em;"
        >
          PDF
        </a>
      )}
      {doi && (
        <a
          href={`https://doi.org/${doi}`}
          target="_blank"
          rel="noopener"
          style="font-family: var(--font-display); font-size: 12px; color: var(--color-accent); letter-spacing: 0.02em;"
        >
          DOI
        </a>
      )}
    </div>
  )}
</div>
